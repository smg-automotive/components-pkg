{
  "name": "@smg-automotive/components",
  "version": "0.0.0-development",
  "description": "SMG Automotive components library",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./fonts/hosted": {
      "import": {
        "types": "./dist/fonts/esm/types/Hosted.d.mts",
        "default": "./dist/fonts/esm/Hosted.js"
      },
      "require": {
        "types": "./dist/fonts/esm/types/Hosted.d.ts",
        "default": "./dist/fonts/cjs/Hosted.js"
      }
    }
  },
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "fonts/hosted": [
        "dist/fonts/esm/types/Hosted"
      ]
    }
  },
  "sideEffects": false,
  "files": [
    "dist/**/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "components": "dist/bin/cli"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "start": "http-server ./storybook-static -p 8008",
    "version": "npm run build",
    "build": "rimraf dist && rollup -c",
    "build:storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook build",
    "lint:i18n": "npx sort-locales src/locales/de/dict.json src/locales/en/dict.json src/locales/fr/dict.json src/locales/it/dict.json",
    "lint": "npm run lint:i18n && eslint .",
    "format:i18n": "npm run lint:i18n -- --fix",
    "format": "npm run format:i18n && npm run lint -- --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:debug": "node --inspect-brk --inspect=127.0.0.1:9229 ./node_modules/jest/bin/jest.js --runInBand"
  },
  "author": "SMG Automotive",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/smg-automotive/components-pkg.git"
  },
  "homepage": "https://github.com/smg-automotive/components-pkg#readme",
  "peerDependencies": {
    "@smg-automotive/auth": "^8.10.0 || ^9.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@babel/preset-env": "7.29.2",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@rollup/plugin-alias": "6.0.0",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-image": "3.0.3",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "12.3.0",
    "@smg-automotive/auth": "9.1.4",
    "@smg-automotive/eslint-config": "5.3.12",
    "@storybook/addon-actions": "8.6.18",
    "@storybook/addon-docs": "8.6.18",
    "@storybook/addon-essentials": "8.6.14",
    "@storybook/addon-interactions": "8.6.14",
    "@storybook/addon-links": "8.6.18",
    "@storybook/addon-webpack5-compiler-babel": "4.0.1",
    "@storybook/blocks": "8.6.14",
    "@storybook/components": "8.6.14",
    "@storybook/core": "8.6.14",
    "@storybook/manager-api": "8.6.14",
    "@storybook/preview-api": "8.6.14",
    "@storybook/react": "8.6.18",
    "@storybook/react-webpack5": "8.6.18",
    "@storybook/test": "8.6.18",
    "@storybook/theming": "8.6.14",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/estree": "1.0.8",
    "@types/jest": "30.0.0",
    "@types/react": "19.2.14",
    "@types/react-textarea-autosize": "8.0.0",
    "autoprefixer": "10.5.0",
    "babel-loader": "10.1.1",
    "buffer": "6.0.3",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-storybook": "0.12.0",
    "hast-util-is-element": "3.0.0",
    "http-server": "14.1.1",
    "https-browserify": "1.0.0",
    "is-absolute-url": "5.0.0",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "postcss-flexbugs-fixes": "5.0.2",
    "prop-types": "15.8.1",
    "querystring-es3": "0.2.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "rimraf": "6.1.3",
    "rollup": "4.60.2",
    "rollup-plugin-add-shebang": "0.3.1",
    "rollup-plugin-copy": "3.5.0",
    "rollup-plugin-dts": "6.4.1",
    "rollup-plugin-executable": "1.6.3",
    "rollup-plugin-peer-deps-external": "2.2.4",
    "semantic-release": "25.0.3",
    "space-separated-tokens": "2.0.2",
    "storybook": "8.6.18",
    "stream-http": "3.2.0",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "tsconfig-paths-webpack-plugin": "4.2.0",
    "typescript": "6.0.3",
    "unist-util-visit": "5.1.0",
    "webpack": "5.106.2"
  },
  "dependencies": {
    "@chakra-ui/anatomy": "2.3.4",
    "@chakra-ui/react": "2.10.9",
    "@chakra-ui/styled-system": "2.12.0",
    "@chakra-ui/system": "2.6.2",
    "@chakra-ui/theme-tools": "2.2.6",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@smg-automotive/i18n-pkg": "3.2.0",
    "@smg-automotive/phrase-pkg": "1.1.0",
    "@types/fs-extra": "11.0.4",
    "embla-carousel-react": "8.6.0",
    "framer-motion": "12.38.0",
    "fs-extra": "11.3.4",
    "fuse.js": "7.3.0",
    "globals": "17.4.0",
    "merge-json-file": "1.0.1",
    "use-debounce": "10.1.1",
    "yargs": "18.0.0"
  },
  "overrides": {
    "eslint": "latest"
  }
}
